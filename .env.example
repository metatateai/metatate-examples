# Offline mode is the default.
METATATE_EXAMPLES_MODE=offline

# Live mode uses the Snowflake Native App canonical SQL tool layer.
# Set METATATE_EXAMPLES_MODE=live after these values are configured.

# Preferred: reuse a Snowflake Python connector / Snow CLI connection profile.
# If your connections.toml is not in the connector default location, set
# SNOWFLAKE_CONNECTIONS_FILE as an absolute path.
SNOWFLAKE_CONNECTION_NAME=your-profile-name
SNOWFLAKE_ROLE=NAC
# SNOWFLAKE_CONNECTIONS_FILE=/absolute/path/to/connections.toml

# Alternative: set connector values directly.
SNOWFLAKE_ACCOUNT=your-org-your-account
SNOWFLAKE_USER=you@example.com
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_AUTHENTICATOR=externalbrowser

# Optional PAT mode. Keep the PAT secret in your shell, not in this file.
# export METATATE_EXAMPLES_PAT='<snowflake-pat-secret>'
# SNOWFLAKE_PAT_ENV=METATATE_EXAMPLES_PAT

METATATE_APP_NAME=METATATE_APP
