# Offline mode is the default.
METATATE_EXAMPLES_MODE=offline

# Live mode uses the Snowflake-managed Metatate MCP server.
# Set METATATE_EXAMPLES_MODE=live after these values are configured.

# Full managed MCP endpoint. This is the same endpoint used by Claude Code,
# Cortex Code, and other MCP clients.
METATATE_MCP_URL=https://<account-url>/api/v2/databases/METATATE_APP/schemas/CORE/mcp-servers/METATATE_MCP

# Role used by the PAT. Keep this aligned with the PAT role restriction.
SNOWFLAKE_ROLE=NAC

# Keep the PAT secret in your shell, not in this file.
# export METATATE_EXAMPLES_PAT='<snowflake-pat-secret>'
METATATE_MCP_PAT_ENV=METATATE_EXAMPLES_PAT
METATATE_MCP_TOKEN_TYPE=PROGRAMMATIC_ACCESS_TOKEN

# Optional if you prefer constructing the endpoint from parts instead of using
# METATATE_MCP_URL.
# METATATE_MCP_ACCOUNT_URL=https://<account-url>
# METATATE_APP_NAME=METATATE_APP
# METATATE_MCP_SCHEMA=CORE
# METATATE_MCP_SERVER_NAME=METATATE_MCP

METATATE_APP_NAME=METATATE_APP
