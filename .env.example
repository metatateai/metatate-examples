# Offline mode is the default: committed fixtures, no account or endpoint.
METATATE_EXAMPLES_MODE=offline

# --- Live mode: your Metatate Cloud workspace --------------------------------
# No workspace yet? Create one free (app.getmetatate.com/sign-up?ref=examples),
# load the AcmeCloud demo from the dashboard banner, then set
# METATATE_EXAMPLES_MODE=live once these values are configured.
# See docs/live-mode-saas.md.

# The full MCP endpoint from the workspace MCP module's Connect tab.
METATATE_MCP_URL=https://<your-workspace-mcp-host>/mcp

# Keep the access token in your shell, not in this file (MCP module -> Tokens):
#   export METATATE_SAAS_MCP_TOKEN=mtt_...
METATATE_MCP_PAT_ENV=METATATE_SAAS_MCP_TOKEN

METATATE_MCP_TIMEOUT_SECONDS=120
METATATE_MCP_RETRY_ATTEMPTS=4
METATATE_MCP_RETRY_BACKOFF_SECONDS=1

# Optional identifier defaults for 1-/2-part table names:
# METATATE_SAAS_DEFAULT_DATABASE=acmecloud_demo
# METATATE_SAAS_DEFAULT_SCHEMA=public

# Snowflake Native App examples moved to
# https://github.com/metatateai/metatate-snowflake-examples
